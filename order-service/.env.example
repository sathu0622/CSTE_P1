PORT=4003
NODE_ENV=development
MONGO_URI=mongodb://order-mongo:27017/orderdb
JWT_SECRET=replace_with_secure_secret
# Docker Compose: http://product-service:4002 | Azure: https://<product-app>.<region>.azurecontainerapps.io (no trailing slash)
PRODUCT_SERVICE_URL=http://product-service:4002
CORS_ORIGIN=*
RATE_LIMIT_MAX=200
SERVICE_SHARED_SECRET=replace_with_shared_secret